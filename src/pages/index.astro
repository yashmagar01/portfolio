---
import ExplorerLayout from "../layouts/ExplorerLayout.astro";
import { getCollection, getEntry } from "astro:content";
import {
    ArrowUpRight,
    Play,
    Calendar,
    Rss,
} from "lucide-react";

// Fetch all docs for computing posts, tags, videos, and table of contents
const allDocs = await getCollection("docs");

// Exclude standalone files from blog posts list
const blogPosts = allDocs.filter(
    (doc) => doc.id !== "welcome" && doc.id !== "about" && doc.id !== "privacy" && doc.id !== "resume" && doc.id !== "contact" && !doc.id.startsWith("projects") && !doc.id.startsWith("vlogs")
);

// 1. Tags section: all tags as chips with counts
const tagCounts: Record<string, number> = {};
blogPosts.forEach((post) => {
    const tags = post.data.tags || [];
    tags.forEach((tag: string) => {
        const cleaned = tag.trim().toLowerCase();
        if (cleaned) {
            tagCounts[cleaned] = (tagCounts[cleaned] || 0) + 1;
        }
    });
});
const sortedTags = Object.entries(tagCounts)
    .sort((a, b) => b[1] - a[1]);

// 2. Recent Posts: top 6 recent posts, excluding videos
const recentPosts = blogPosts
    .filter((post) => !(post.data.tags || []).map((t: string) => t.toLowerCase()).includes("video"))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 6);

// 3. Recent Videos: top 4 posts with video tag, showing YouTube thumbnails
const videoPosts = blogPosts
    .filter((post) => (post.data.tags || []).map((t: string) => t.toLowerCase()).includes("video"))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 4);

// Helper to extract YouTube video ID from post body
function getYoutubeId(content: string): string | null {
    const socialMatch = content.match(/<SocialEmbed[^>]*id=["']([a-zA-Z0-9_-]+)["']/);
    if (socialMatch && content.includes('platform="youtube"')) {
        return socialMatch[1];
    }
    const embedMatch = content.match(/youtube\.com\/embed\/([a-zA-Z0-9_-]+)/);
    if (embedMatch) return embedMatch[1];
    const watchMatch = content.match(/v=([a-zA-Z0-9_-]+)/);
    if (watchMatch) return watchMatch[1];
    const beMatch = content.match(/youtu\.be\/([a-zA-Z0-9_-]+)/);
    if (beMatch) return beMatch[1];
    return null;
}

const recentVideosWithMetadata = videoPosts.map((post) => {
    const ytId = getYoutubeId(post.body || "");
    const thumbnail = ytId ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` : null;
    return {
        ...post,
        ytId,
        thumbnail
    };
});

// 4. Content Graph: calculate posts per day for the last 53 weeks
const postsPerDay: Record<string, number> = {};
blogPosts.forEach((post) => {
    if (post.data.date) {
        const dateStr = new Date(post.data.date).toISOString().split("T")[0];
        postsPerDay[dateStr] = (postsPerDay[dateStr] || 0) + 1;
    }
});

const postDates = blogPosts
    .map(p => p.data.date ? new Date(p.data.date) : null)
    .filter((d): d is Date => d !== null);

const latestPostDate = postDates.length > 0
    ? new Date(Math.max(...postDates.map(d => d.getTime())))
    : new Date();

const today = new Date();
const baseDate = latestPostDate > today ? latestPostDate : today;

const currentDayOfWeek = baseDate.getDay();
const endDate = new Date(baseDate);
endDate.setDate(baseDate.getDate() + (6 - currentDayOfWeek));

const startDate = new Date(endDate);
startDate.setDate(endDate.getDate() - 370);

const daysArray: { dateStr: string; count: number; date: Date }[] = [];
const tempDate = new Date(startDate);
while (tempDate <= endDate) {
    const dateStr = tempDate.toISOString().split("T")[0];
    const count = postsPerDay[dateStr] || 0;
    daysArray.push({
        dateStr,
        count,
        date: new Date(tempDate)
    });
    tempDate.setDate(tempDate.getDate() + 1);
}

const lastYearPostsCount = daysArray.reduce((acc, d) => acc + d.count, 0);

interface WeekNode {
    days: typeof daysArray;
    monthLabel: string | null;
}
const weeks: WeekNode[] = [];
let lastMonth = -1;

for (let i = 0; i < daysArray.length; i += 7) {
    const weekDays = daysArray.slice(i, i + 7);
    let label: string | null = null;
    const firstDay = weekDays[0].date;
    const month = firstDay.getMonth();

    if (month !== lastMonth) {
        label = firstDay.toLocaleDateString(undefined, { month: 'short' });
        lastMonth = month;
    }

    weeks.push({
        days: weekDays,
        monthLabel: label
    });
}

// 5. Posts tree (for the archive section)
interface TreeNode {
    name: string;
    posts: typeof blogPosts;
    children: Record<string, TreeNode>;
}

const postsTree: Record<string, TreeNode> = {};

function formatHeaderName(name: string): string {
    if (!name) return "";
    const special: Record<string, string> = {
        "projects": "Projects",
        "vlogs": "Vlogs",
        "blog": "Blog",
        "ai": "AI",
        "web": "Web",
        "backend": "Backend",
        "tools": "Tools",
    };
    if (special[name.toLowerCase()]) return special[name.toLowerCase()];
    return name
        .split("-")
        .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
        .join(" ");
}

blogPosts.forEach((post) => {
    const segments = post.id.split("/");
    let currentLevel = postsTree;

    for (let i = 0; i < segments.length - 1; i++) {
        const seg = segments[i];
        if (!currentLevel[seg]) {
            currentLevel[seg] = {
                name: formatHeaderName(seg),
                posts: [],
                children: {}
            };
        }
        if (i === segments.length - 2) {
            currentLevel[seg].posts.push(post);
        }
        currentLevel = currentLevel[seg].children;
    }
});

function renderTreeHtml(nodeMap: Record<string, TreeNode>, depth = 0): string {
    let html = "";
    const sortedKeys = Object.keys(nodeMap).sort((a, b) => a.localeCompare(b));

    for (const key of sortedKeys) {
        const node = nodeMap[key];
        const headingLevel = 3 + depth;

        let headingClass = "";
        if (headingLevel === 3) {
            headingClass = "editorial-archive-h3";
        } else if (headingLevel === 4) {
            headingClass = "editorial-archive-h4";
        } else {
            headingClass = "editorial-archive-h5";
        }

        html += `<h${headingLevel} class="${headingClass}">${node.name}</h${headingLevel}>`;

        if (node.posts.length > 0) {
            html += `<ul class="editorial-archive-list">`;
            const sortedPosts = [...node.posts].sort((a, b) => (a.data.title || "").localeCompare(b.data.title || ""));
            for (const post of sortedPosts) {
                html += `
                    <li class="editorial-archive-item">
                        <a href="/${post.id}" class="editorial-archive-link">
                            ${post.data.title || post.id}
                        </a>
                    </li>
                `;
            }
            html += `</ul>`;
        }

        if (Object.keys(node.children).length > 0) {
            html += `<div class="editorial-archive-nested">`;
            html += renderTreeHtml(node.children, depth + 1);
            html += `</div>`;
        }
    }

    return html;
}

// Social links — minimal
const socialLinks = [
    { name: "GitHub", href: "https://github.com/yashmagar01" },
    { name: "LinkedIn", href: "https://www.linkedin.com/in/yash-magar/" },
    { name: "YouTube", href: "https://www.youtube.com/@yashmagar01" },
    { name: "X", href: "https://x.com/yashmag50534849" },
    { name: "Email", href: "mailto:yashajaymagar10@gmail.com" },
];

// Format date helper
function formatDate(date: string | Date): string {
    const d = typeof date === 'string' ? new Date(date) : date;
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<ExplorerLayout activePostId="welcome">
    <div class="editorial-root">

        {/* ===== HERO BAND ===== */}
        <section class="editorial-hero">
            <div class="editorial-hero-gradient" aria-hidden="true"></div>
            <div class="editorial-hero-content">
                <span class="editorial-eyebrow">PERSONAL PUBLISHING</span>
                <h1 class="editorial-display">yash ajay magar</h1>
                <p class="editorial-lead">
                    Essays, research notes, technical opinions, and projects —
                    exploring AI, web development, and the future of tools.
                </p>
                <div class="editorial-hero-actions">
                    <a href="/about" class="editorial-btn-primary">About</a>
                    <a href="/rss.xml" class="editorial-btn-secondary">
                        <Rss size={14} />
                        RSS Feed
                    </a>
                </div>
            </div>
        </section>

        {/* ===== RECENT WRITING ===== */}
        <section class="editorial-section">
            <div class="editorial-section-header">
                <span class="editorial-eyebrow">RECENT WRITING</span>
                <a href="/tags" class="editorial-section-link">
                    View all →
                </a>
            </div>

            <div class="editorial-posts-grid">
                {recentPosts.map((post) => (
                    <a
                        href={`/${post.id}`}
                        class="editorial-post-card"
                    >
                        <div class="editorial-post-card-inner">
                            <div class="editorial-post-meta">
                                <time>{formatDate(post.data.date)}</time>
                                {post.data.tags && post.data.tags.slice(0, 2).map((tag: string) => (
                                    <span class="editorial-tag-inline">{tag}</span>
                                ))}
                            </div>
                            <h3 class="editorial-post-title">
                                {post.data.title}
                            </h3>
                            {post.data.summary && (
                                <p class="editorial-post-summary">
                                    {post.data.summary}
                                </p>
                            )}
                        </div>
                        <ArrowUpRight size={16} className="editorial-post-arrow" />
                    </a>
                ))}
            </div>
        </section>

        {/* ===== VIDEOS ===== */}
        {recentVideosWithMetadata.length > 0 && (
            <section class="editorial-section">
                <div class="editorial-section-header">
                    <span class="editorial-eyebrow">VIDEOS</span>
                    <span class="editorial-section-count">{videoPosts.length} videos</span>
                </div>

                <div class="editorial-videos-grid">
                    {recentVideosWithMetadata.map((video) => (
                        <a
                            href={`/${video.id}`}
                            class="editorial-video-card"
                        >
                            <div class="editorial-video-thumb">
                                {video.thumbnail ? (
                                    <img
                                        src={video.thumbnail}
                                        alt={video.data.title}
                                        loading="lazy"
                                    />
                                ) : (
                                    <div class="editorial-video-placeholder">
                                        <Play size={32} />
                                    </div>
                                )}
                                <div class="editorial-video-overlay">
                                    <div class="editorial-play-btn">
                                        <Play size={18} className="fill-white" />
                                    </div>
                                </div>
                            </div>
                            <div class="editorial-video-info">
                                <h3>{video.data.title}</h3>
                                <time>{video.data.date ? formatDate(video.data.date) : ''}</time>
                            </div>
                        </a>
                    ))}
                </div>
            </section>
        )}

        {/* ===== CONTENT GRAPH ===== */}
        <section class="editorial-section">
            <div class="editorial-section-header">
                <span class="editorial-eyebrow">ACTIVITY</span>
                <span class="editorial-section-count">
                    {lastYearPostsCount} posts this year
                </span>
            </div>

            <div class="editorial-graph-card">
                <div class="editorial-graph-container">
                    <div class="editorial-graph-wrapper">
                        {/* Day labels */}
                        <div class="editorial-graph-labels">
                            <span>S</span>
                            <span>M</span>
                            <span>T</span>
                            <span>W</span>
                            <span>T</span>
                            <span>F</span>
                            <span>S</span>
                        </div>

                        {/* Weeks grid */}
                        <div class="editorial-graph-grid">
                            {weeks.map((week, index) => {
                                let responsiveClass = "editorial-graph-col";
                                if (index < 20) {
                                    responsiveClass = "editorial-graph-col editorial-graph-col-desktop";
                                } else if (index < 33) {
                                    responsiveClass = "editorial-graph-col editorial-graph-col-tablet";
                                }

                                return (
                                    <div class={`${responsiveClass}`}>
                                        {week.monthLabel && (
                                            <span class="editorial-graph-month">{week.monthLabel}</span>
                                        )}
                                        {week.days.map((day) => {
                                            let level = "0";
                                            if (day.count === 1) level = "1";
                                            else if (day.count === 2) level = "2";
                                            else if (day.count >= 3) level = "3";

                                            return (
                                                <div class="editorial-graph-cell-wrap" title={`${day.count} post${day.count === 1 ? '' : 's'} on ${formatDate(day.date)}`}>
                                                    <div class={`editorial-graph-cell editorial-graph-level-${level}`} />
                                                </div>
                                            );
                                        })}
                                    </div>
                                );
                            })}
                        </div>
                    </div>

                    {/* Legend */}
                    <div class="editorial-graph-legend">
                        <span>Less</span>
                        <div class="editorial-graph-cell editorial-graph-level-0" />
                        <div class="editorial-graph-cell editorial-graph-level-1" />
                        <div class="editorial-graph-cell editorial-graph-level-2" />
                        <div class="editorial-graph-cell editorial-graph-level-3" />
                        <span>More</span>
                    </div>
                </div>
            </div>
        </section>

        {/* ===== ARCHIVE ===== */}
        <section class="editorial-section">
            <div class="editorial-section-header">
                <span class="editorial-eyebrow">ARCHIVE</span>
                <span class="editorial-section-count">{blogPosts.length} entries</span>
            </div>

            <div class="editorial-archive-card">
                <Fragment set:html={renderTreeHtml(postsTree)} />
            </div>
        </section>

        {/* ===== TOPICS ===== */}
        <section class="editorial-section">
            <div class="editorial-section-header">
                <span class="editorial-eyebrow">TOPICS</span>
                <span class="editorial-section-count">{sortedTags.length} tags</span>
            </div>

            <div class="editorial-tags-wrap">
                {sortedTags.map(([tagName, count]) => (
                    <a
                        href={`/tags/${tagName}`}
                        class="editorial-tag-pill"
                    >
                        {tagName}
                        <span class="editorial-tag-count">{count}</span>
                    </a>
                ))}
            </div>
        </section>

        {/* ===== CONNECT ===== */}
        <section class="editorial-section editorial-section-last">
            <div class="editorial-section-header">
                <span class="editorial-eyebrow">CONNECT</span>
            </div>
            <div class="editorial-connect-row">
                {socialLinks.map((social) => (
                    <a
                        href={social.href}
                        target={social.href.startsWith("mailto") ? undefined : "_blank"}
                        rel={social.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
                        class="editorial-connect-link"
                    >
                        {social.name}
                        <ArrowUpRight size={12} />
                    </a>
                ))}
            </div>
        </section>
    </div>
</ExplorerLayout>

<style>
    /* ===== EDITORIAL DESIGN SYSTEM ===== */

    .editorial-root {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 32px 96px;
    }

    /* ===== HERO ===== */
    .editorial-hero {
        position: relative;
        padding: 96px 0 64px;
        overflow: hidden;
    }

    .editorial-hero-gradient {
        position: absolute;
        top: -40%;
        right: -20%;
        width: 80%;
        height: 200%;
        background: radial-gradient(ellipse at 30% 50%,
            rgba(0, 124, 240, 0.08) 0%,
            rgba(0, 223, 216, 0.06) 20%,
            rgba(121, 40, 202, 0.06) 40%,
            rgba(255, 0, 128, 0.04) 60%,
            transparent 80%
        );
        filter: blur(60px);
        pointer-events: none;
    }

    .editorial-hero-content {
        position: relative;
    }

    .editorial-display {
        font-family: var(--font-body);
        font-size: 48px;
        font-weight: 600;
        line-height: 48px;
        letter-spacing: -2.4px;
        color: var(--fg-primary);
        margin: 12px 0 16px;
    }

    .editorial-lead {
        font-size: 16px;
        line-height: 24px;
        color: var(--fg-secondary);
        max-width: 520px;
        margin: 0 0 32px;
    }

    .editorial-hero-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .editorial-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0 14px;
        height: 40px;
        background: var(--fg-primary);
        color: var(--bg-main);
        font-size: 14px;
        font-weight: 500;
        border-radius: 100px;
        text-decoration: none;
        transition: opacity 0.15s;
    }
    .editorial-btn-primary:hover { opacity: 0.85; }

    .editorial-btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 0 14px;
        height: 40px;
        background: var(--bg-sidebar);
        color: var(--fg-primary);
        font-size: 14px;
        font-weight: 500;
        border: 1px solid var(--border-main);
        border-radius: 100px;
        text-decoration: none;
        transition: border-color 0.15s;
    }
    .editorial-btn-secondary:hover { border-color: var(--fg-secondary); }

    /* ===== EYEBROW ===== */
    .editorial-eyebrow {
        font-family: var(--font-mono);
        font-size: 12px;
        font-weight: 500;
        line-height: 16px;
        letter-spacing: 0.05em;
        color: var(--fg-secondary);
        text-transform: uppercase;
    }

    /* ===== SECTIONS ===== */
    .editorial-section {
        padding-top: 64px;
    }
    .editorial-section-last {
        padding-bottom: 32px;
    }

    .editorial-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border-main);
        margin-bottom: 24px;
    }

    .editorial-section-link {
        font-size: 14px;
        color: var(--color-link, #3794ff);
        text-decoration: none;
        font-weight: 500;
    }
    .editorial-section-link:hover { text-decoration: underline; }

    .editorial-section-count {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-secondary);
    }

    /* ===== POST CARDS ===== */
    .editorial-posts-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .editorial-post-card {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 0;
        border-bottom: 1px solid var(--border-main);
        text-decoration: none;
        color: inherit;
        transition: background-color 0.15s;
    }
    .editorial-post-card:first-child {
        padding-top: 0;
    }
    .editorial-post-card:hover {
        background: none;
    }

    .editorial-post-card-inner {
        flex: 1;
        min-width: 0;
    }

    .editorial-post-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: var(--fg-secondary);
        margin-bottom: 6px;
    }
    .editorial-post-meta time {
        font-family: var(--font-mono);
        color: var(--fg-secondary);
    }

    .editorial-tag-inline {
        font-size: 11px;
        color: var(--fg-secondary);
        padding: 1px 6px;
        border: 1px solid var(--border-main);
        border-radius: 100px;
    }

    .editorial-post-title {
        font-size: 16px;
        font-weight: 600;
        line-height: 24px;
        letter-spacing: -0.3px;
        color: var(--fg-primary);
        margin: 0 0 4px;
        transition: color 0.15s;
    }
    .editorial-post-card:hover .editorial-post-title {
        color: var(--color-link, #3794ff);
    }

    .editorial-post-summary {
        font-size: 14px;
        line-height: 20px;
        color: var(--fg-secondary);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    :global(.editorial-post-arrow) {
        color: var(--fg-secondary);
        flex-shrink: 0;
        margin-top: 4px;
        opacity: 0;
        transform: translate(-4px, 4px);
        transition: all 0.2s;
    }
    .editorial-post-card:hover :global(.editorial-post-arrow) {
        opacity: 1;
        transform: translate(0, 0);
        color: var(--color-link, #3794ff);
    }

    /* ===== VIDEO CARDS ===== */
    .editorial-videos-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .editorial-video-card {
        display: block;
        border: 1px solid var(--border-main);
        border-radius: 12px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        background: var(--bg-sidebar);
        transition: border-color 0.15s;
    }
    .editorial-video-card:hover {
        border-color: var(--fg-secondary);
    }

    .editorial-video-thumb {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--bg-main);
    }
    .editorial-video-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s;
    }
    .editorial-video-card:hover .editorial-video-thumb img {
        transform: scale(1.03);
    }
    .editorial-video-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--fg-secondary);
    }

    .editorial-video-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.3);
        opacity: 0;
        transition: opacity 0.2s;
    }
    .editorial-video-card:hover .editorial-video-overlay {
        opacity: 1;
    }
    .editorial-play-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--fg-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .editorial-video-info {
        padding: 12px 16px;
    }
    .editorial-video-info h3 {
        font-size: 14px;
        font-weight: 600;
        line-height: 20px;
        color: var(--fg-primary);
        margin: 0 0 4px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .editorial-video-info time {
        font-family: var(--font-mono);
        font-size: 12px;
        color: var(--fg-secondary);
    }

    /* ===== CONTENT GRAPH ===== */
    .editorial-graph-card {
        border: 1px solid var(--border-main);
        border-radius: 12px;
        background: var(--bg-sidebar);
        padding: 24px;
    }

    .editorial-graph-container {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .editorial-graph-wrapper {
        display: flex;
        gap: 8px;
        padding-top: 20px;
    }

