---
import ViewStatus from "./ViewStatus.astro";
import { Code2 } from "lucide-react";

import githubIcon from "../assets/svg/github.svg?raw";
import linkedinIcon from "../assets/svg/linkedin.svg?raw";
import youtubeIcon from "../assets/svg/youtube.svg?raw";
import twitterIcon from "../assets/svg/twitter.svg?raw";
import rssIcon from "../assets/svg/rss.svg?raw";

const socialLinks = [
    { icon: githubIcon, href: "https://github.com/yashmagar01", label: "GitHub" },
    { icon: linkedinIcon, href: "https://www.linkedin.com/in/yash-magar/", label: "LinkedIn" },
    { icon: twitterIcon, href: "https://x.com/yashmag50534849", label: "X / Twitter" },
    { icon: youtubeIcon, href: "https://www.youtube.com/@yashmagar01", label: "YouTube" },
    { icon: rssIcon, href: "/rss.xml", label: "RSS Feed" },
];
---

<div
    class="bg-[var(--bg-status)] text-white z-50 relative pb-[env(safe-area-inset-bottom)]"
>
    <div
        class="h-[20px] flex items-center justify-between px-3 text-[11px] select-none"
    >
        <div class="flex items-center space-x-1 h-full">
            <a
                href="/"
                class="flex items-center hover:bg-white/20 px-2 rounded cursor-pointer h-[18px] transition-colors font-semibold gap-1.5"
            >
                <Code2 size={11} />
                <span class="hidden sm:inline tracking-tight">yash ajay magar</span>
            </a>
            <span class="hidden sm:inline opacity-40 text-[10px] px-1">·</span>
            <a
                href="/resume"
                class="hidden sm:flex items-center hover:bg-white/20 px-2 rounded cursor-pointer h-[18px] transition-colors text-white/80 hover:text-white text-[11px] no-underline"
            >
                AI Journalist
            </a>
        </div>

        <div class="flex items-center space-x-0.5 h-full">
            {
                socialLinks.map((link) => (
                    <a
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center justify-center hover:bg-white/20 w-[24px] h-[18px] rounded cursor-pointer transition-colors"
                        title={link.label}
                    >
                        <span
                            class="w-3 h-3 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full [&>svg]:fill-current"
                            set:html={link.icon}
                        />
                    </a>
                ))
            }
            <div
                class="hidden sm:flex items-center hover:bg-white/10 px-2 cursor-pointer h-full transition-colors ml-1 border-l border-white/20"
            >
                <ViewStatus />
            </div>
        </div>
    </div>
</div>
